---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import NavBar from '@/components/NavBar.astro';
import ConceptCard from '@/components/ConceptCard.astro';
import DeferredProfile from '@/components/DeferredProfile.astro';
import SiteFooter from '@/components/SiteFooter.astro';

const concepts = (await getCollection('concepts')).sort((a, b) => a.data.order - b.data.order);
const highlighted = concepts.slice(0, 4);
const categories = ['All', ...new Set(concepts.map((concept) => concept.data.tag))];
---

<BaseLayout title="20 API Concepts for System Design">
  <NavBar />
  <main>
    <section class="hero-section container">
      <div class="hero-copy">
        <p class="eyebrow">System design foundations</p>
        <h1>Master the foundation: 20 essential API concepts</h1>
        <p class="hero-lede">
          A focused guide to the building blocks behind reliable APIs: protocol semantics,
          security boundaries, performance controls, and production operations.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="#concepts">
            <span class="material-symbols-outlined" aria-hidden="true">grid_view</span>
            Explore concepts
          </a>
          <a class="button secondary" href="#resources">
            <span class="material-symbols-outlined" aria-hidden="true">terminal</span>
            View patterns
          </a>
        </div>
      </div>
      <figure class="hero-visual glass-panel">
        <img
          src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=1600&q=82"
          alt="Server racks and network lights representing API infrastructure"
        />
        <figcaption>
          <span>API surface</span>
          <strong>20 concepts</strong>
        </figcaption>
      </figure>
    </section>

    <section id="resources" class="resource-band">
      <div class="container resource-grid">
        <div>
          <p class="eyebrow">From design to production</p>
          <h2>API thinking that scales beyond a single endpoint</h2>
        </div>
        <div class="resource-list">
          {highlighted.map((concept) => (
            <a href="#concepts" style={`--accent:${concept.data.accent}`}>
              <span class="material-symbols-outlined" aria-hidden="true">{concept.data.icon}</span>
              <span>{concept.data.title}</span>
            </a>
          ))}
        </div>
        <DeferredProfile server:defer />
      </div>
    </section>

    <section id="concepts" class="concept-section container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Concept explorer</p>
          <h2>Build a sharper API vocabulary</h2>
        </div>
        <p>Each card is a concise system-design primitive with a practical category and maturity level.</p>
      </div>
      <div class="concept-controls">
        <div class="concept-search glass-panel">
          <span class="material-symbols-outlined" aria-hidden="true">search</span>
          <input
            id="concept-search"
            type="search"
            placeholder="Search API concepts..."
            aria-label="Search API concepts"
            autocomplete="off"
          />
        </div>
        <div class="category-filters" aria-label="Filter concepts by category">
          {categories.map((category, index) => (
            <button
              type="button"
              class:list={['category-filter', { active: index === 0 }]}
              data-category-filter={category.toLowerCase()}
              aria-pressed={index === 0 ? 'true' : 'false'}
            >
              {category}
            </button>
          ))}
        </div>
      </div>
      <div class="concept-grid">
        {concepts.map((concept) => (
          <ConceptCard {...concept.data} href={`/concepts/${concept.id}`} />
        ))}
      </div>
      <p class="concept-empty" hidden>No concepts match your search.</p>
    </section>

    <section id="newsletter" class="newsletter-section container glass-panel">
      <div>
        <p class="eyebrow">Type-safe action demo</p>
        <h2>Get the API design briefing</h2>
      </div>
      <form action="/actions/subscribe" method="POST">
        <input name="email" type="email" required placeholder="you@example.com" aria-label="Email address" />
        <button type="submit">
          <span class="material-symbols-outlined" aria-hidden="true">send</span>
          Subscribe
        </button>
      </form>
    </section>
  </main>
  <SiteFooter />
  <script>
    const searchInput = document.querySelector<HTMLInputElement>('#concept-search');
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-concept-card]'));
    const categoryButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-category-filter]'));
    const emptyState = document.querySelector<HTMLElement>('.concept-empty');
    let activeCategory = 'all';

    function updateConceptFilters() {
      const query = searchInput?.value.trim().toLowerCase() ?? '';
      let visibleCount = 0;

      cards.forEach((card) => {
        const matchesSearch = !query || card.dataset.search?.includes(query);
        const matchesCategory = activeCategory === 'all' || card.dataset.category === activeCategory;
        const isVisible = matchesSearch && matchesCategory;
        card.hidden = !isVisible;
        if (isVisible) visibleCount += 1;
      });

      if (emptyState) {
        emptyState.hidden = visibleCount > 0;
      }
    }

    searchInput?.addEventListener('input', updateConceptFilters);

    categoryButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activeCategory = button.dataset.categoryFilter ?? 'all';
        categoryButtons.forEach((categoryButton) => {
          const isActive = categoryButton === button;
          categoryButton.classList.toggle('active', isActive);
          categoryButton.setAttribute('aria-pressed', String(isActive));
        });
        updateConceptFilters();
      });
    });
  </script>
</BaseLayout>
