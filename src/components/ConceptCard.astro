---
interface Props {
  icon: string;
  title: string;
  summary: string;
  tag: string;
  level: string;
  accent: string;
  methods?: string[];
  href?: string;
}

const { icon, title, summary, tag, level, accent, methods = [], href = '#' } = Astro.props;
const searchText = [title, summary, tag, level, ...methods].join(' ').toLowerCase();
---

<a
  class="concept-card glass-panel"
  href={href}
  style={`--accent:${accent}`}
  data-concept-card
  data-category={tag.toLowerCase()}
  data-search={searchText}
>
  <div class="card-accent" aria-hidden="true"></div>
  <div class="card-main">
    <span class="material-symbols-outlined card-icon" aria-hidden="true">{icon}</span>
    <h3>{title}</h3>
    {methods.length > 0 && (
      <div class="method-list" aria-label={`${title} method examples`}>
        {methods.map((method) => <span>{method}</span>)}
      </div>
    )}
    <p>{summary}</p>
  </div>
  <div class="card-meta">
    <span class="tag">{tag}</span>
    <span class="level">{level}</span>
    <span class="material-symbols-outlined arrow" aria-hidden="true">arrow_forward</span>
  </div>
</a>
