---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import NavBar from '@/components/NavBar.astro';
import ConceptCard from '@/components/ConceptCard.astro';
import DeferredProfile from '@/components/DeferredProfile.astro';

const concepts = (await getCollection('concepts')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Advanced Astro Concepts | API Explorer">
  <NavBar />
  <main class="container" style="padding:3rem 0 4rem; display:grid; gap:2rem;">
    <section style="text-align:center;display:grid;gap:1.2rem;">
      <h1 style="font-size:clamp(2rem,5vw,4rem); line-height:1.1; margin:0;">Master Astro Architecture & API Design</h1>
      <p style="max-width:780px;margin:0 auto;color:var(--muted);font-size:1.2rem;line-height:1.5;">Server islands, hybrid rendering, content collections, actions, middleware, and extensibility — wrapped in a premium UX/UI layout based on modern CSS Grid + Flex patterns.</p>
      <img src="https://images.unsplash.com/photo-1535223289827-42f1e9919769?auto=format&fit=crop&w=1600&q=80" alt="network visualization" style="width:min(920px,100%);margin:1rem auto 0;border-radius:18px;border:1px solid var(--line);padding:.45rem;" />
    </section>

    <section id="architecture" style="display:grid;grid-template-columns:1.3fr .9fr;gap:1rem;align-items:start;">
      <div class="glass" style="border-radius:16px;padding:1.2rem;">
        <h2 style="margin:0;">Advanced Architecture</h2>
        <ul style="margin:.7rem 0 0;color:var(--muted);line-height:1.8;padding-left:1rem;">
          <li><strong>Hybrid Rendering:</strong> this site is static-first with a dynamic SSR route at <code>/live</code>.</li>
          <li><strong>Server Islands:</strong> profile card below renders deferred via server.</li>
          <li><strong>View Transitions-ready:</strong> structure prepared for smooth route changes.</li>
          <li><strong>Middleware:</strong> custom headers demonstrate centralized request policy.</li>
        </ul>
      </div>
      <DeferredProfile server:defer />
    </section>

    <section id="newsletter" class="glass" style="border-radius:16px;padding:1rem 1.2rem;">
      <h2 style="margin:0 0 .7rem;">Astro Actions Demo</h2>
      <form action="/actions/subscribe" method="POST" style="display:flex;gap:.6rem;flex-wrap:wrap;">
        <input name="email" type="email" required placeholder="you@example.com" style="flex:1;min-width:240px;padding:.72rem;border-radius:.65rem;border:1px solid var(--line);" />
        <button style="padding:.72rem 1rem;border:none;background:#0f172a;color:white;border-radius:.65rem;">Subscribe</button>
      </form>
    </section>

    <section id="concepts">
      <div style="display:flex;justify-content:space-between;align-items:end;gap:1rem; margin-bottom:1rem;">
        <h2 style="margin:0;font-size:2rem;">Concept Explorer</h2>
        <small style="color:var(--muted);">Type-safe content powered by Astro Content Collections</small>
      </div>
      <div class="grid-cards">
        {concepts.map((concept) => (
          <ConceptCard {...concept.data} />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
