---
export const prerender = false;
const now = new Date();
---

<html lang="en">
  <head><meta charset="utf-8" /><meta name="viewport" content="width=device-width" /><title>Live SSR Route</title></head>
  <body style="font-family:system-ui;padding:2rem;">
    <h1>Live Route (SSR)</h1>
