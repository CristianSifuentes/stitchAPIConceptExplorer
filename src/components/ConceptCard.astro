---
interface Props {
  icon: string;
  title: string;
  summary: string;
  tag: string;
  level: string;
}

const { icon, title, summary, tag, level } = Astro.props;
---

<article class="card glass">
  <div>
    <p style="font-size:1.2rem; margin:.2rem 0;">{icon}</p>
    <h3 style="margin:.2rem 0;font-size:1.6rem;">{title}</h3>
    <p style="margin:0;color:var(--muted);line-height:1.5;">{summary}</p>
  </div>
  <div style="display:flex;justify-content:space-between;align-items:center; margin-top:1rem;">
    <small style="background:#e2e8f0; border-radius:999px; padding:.2rem .65rem; letter-spacing:.09em;">{tag}</small>
    <small style="font-weight:700; color:#0c4a6e;">{level}</small>
  </div>
</article>
